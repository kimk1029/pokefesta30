    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "20.16.5",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "prisma": "^6.19.3",
    "tsx": "^4.20.6",
    "typescript": "5.6.2"
  }
}
