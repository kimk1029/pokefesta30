    "db:reset": "prisma migrate reset",
    "deploy:admin": "cd admin && npm install && npm run build && cd .. && (pm2 delete pokefesta30-admin || true) && pm2 start ecosystem.config.cjs --only pokefesta30-admin && pm2 save && pm2 status"
