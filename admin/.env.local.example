# admin Basic Auth 크레덴셜
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# 메인 앱과 같은 Supabase DB 공유.
# (pooler / 6543 + ?pgbouncer=true — 런타임 쿼리용)
DATABASE_URL="postgresql://postgres.xxxxxxxxxxxxxxxx:[YOUR-PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# 마이그레이션 실행 시 필요 (admin 에서 prisma migrate 돌릴 경우).
DIRECT_URL="postgresql://postgres.xxxxxxxxxxxxxxxx:[YOUR-PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres"

# 런타임 포트 (기본 3010). pm2 ecosystem 에서도 주입 가능.
PORT=3010
