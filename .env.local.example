# ==========================================
# App
# ==========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 세션/JWT 서명용. 생성: openssl rand -base64 48
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# ==========================================
# Database - PostgreSQL
# ==========================================
# APP_ENV=production 일 때만 DATABASE_URL_PRODUCTION 사용.
# 그 외(미지정, staging 등)에는 DATABASE_URL_STAGING 사용 (= 시놀로지).
# 둘 다 비어있으면 앱은 mock 데이터로 동작.
APP_ENV=staging

DATABASE_URL_STAGING=postgres://pokefesta:CHANGE_ME@kimk1029.synology.me:5432/pokefesta30
DATABASE_URL_PRODUCTION=postgres://pokefesta:CHANGE_ME@127.0.0.1:5432/pokefesta30

# self-signed SSL 쓰는 DB (시놀로지 등)면 1 로 설정
DATABASE_SSL_INSECURE=0

# ==========================================
# Kakao Login
# https://developers.kakao.com
# ==========================================
NEXT_PUBLIC_KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:3000/api/auth/callback/kakao

# Kakao Maps
NEXT_PUBLIC_KAKAO_MAP_KEY=

# ==========================================
# Naver Login
# https://developers.naver.com/apps
# ==========================================
NEXT_PUBLIC_NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=http://localhost:3000/api/auth/callback/naver

# ==========================================
# Google Login
# https://console.cloud.google.com/apis/credentials
# ==========================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# ==========================================
# Optional
# ==========================================
SENTRY_DSN=
RESEND_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=
