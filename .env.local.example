# ==========================================
# App
# ==========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 세션/JWT 서명용. 생성: openssl rand -base64 48
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# ==========================================
# Database - PostgreSQL (Prisma)
# ==========================================
# 기본은 DATABASE_URL (= staging). Prisma CLI 도 이 값을 읽음.
# APP_ENV=production 이면 런타임은 DATABASE_URL_PRODUCTION 으로 스위치.
APP_ENV=staging
DATABASE_URL=postgres://pokefesta:CHANGE_ME@127.0.0.1:5432/pokefesta30
DATABASE_URL_PRODUCTION=postgres://pokefesta:CHANGE_ME@127.0.0.1:5432/pokefesta30

# ==========================================
# Kakao Login
# https://developers.kakao.com
# ==========================================
NEXT_PUBLIC_KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:3000/api/auth/callback/kakao

# Kakao Maps
NEXT_PUBLIC_KAKAO_MAP_KEY=

# ==========================================
# Naver Login
# https://developers.naver.com/apps
# ==========================================
NEXT_PUBLIC_NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=http://localhost:3000/api/auth/callback/naver

# ==========================================
# Google Login
# https://console.cloud.google.com/apis/credentials
# ==========================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# ==========================================
# eBay Browse API (카드 시세)
# https://developer.ebay.com/my/keys
# EBAY_ENV=production 이 기본. sandbox 테스트 시 'sandbox' 로.
# MARKETPLACE_ID: EBAY_US / EBAY_GB / EBAY_DE … (EBAY_KR 없음)
# ==========================================
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_ENV=production

# ==========================================
# Optional
# ==========================================
SENTRY_DSN=
RESEND_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=
