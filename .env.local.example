# ==========================================
# App
# ==========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 세션/JWT 서명용. 생성: openssl rand -base64 48
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# ==========================================
# Admin (어드민 화이트리스트)
# /admin 접근을 허용할 이메일 목록 — 콤마로 여러 개 등록.
# 비교는 소문자/공백 트림 후 수행.
# 예) ADMIN_EMAILS="kimk10291@gmail.com, ops@pokefesta.com"
# ==========================================
ADMIN_EMAILS=

# ==========================================
# Database - PostgreSQL (Supabase 권장)
# ==========================================
# Supabase 콘솔 → Project Settings → Database → Connection string 에서 복사.
#
#  DATABASE_URL  : pooler(:6543) + ?pgbouncer=true   ← 런타임 쿼리용 (서버리스/Vercel)
#  DIRECT_URL    : 직접(:5432)                        ← prisma migrate 전용
#
# [YOUR-PASSWORD] 부분은 Supabase 가입 시 설정한 DB 비밀번호로 치환.
APP_ENV=production
DATABASE_URL="postgresql://postgres.lyrhunyilwtupdwaydez:[YOUR-PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.lyrhunyilwtupdwaydez:[YOUR-PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres"

# (옵션) 스테이징/프로덕션 DB 분리 시에만 값 지정. 같은 DB 쓰면 비워두거나 삭제.
DATABASE_URL_PRODUCTION=

# ==========================================
# Kakao Login
# https://developers.kakao.com
# ==========================================
NEXT_PUBLIC_KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:3000/api/auth/callback/kakao

# Naver Map (NCP Web Dynamic Map v3)
# 공식 가이드: https://www.ncloud.com/product/applicationService/maps
# 공식 SDK 예제: https://github.com/navermaps/maps.js.ncp
#
# 발급 순서:
#   1) console.ncloud.com → Services → AI·Application Service → Maps → 이용신청
#   2) Application 등록 → "Web Dynamic Map" 체크
#   3) "Web 서비스 URL" 섹션에 아래 도메인 전부 등록 (미등록 시 401/인증실패):
#        https://poke-30.com
#        https://www.poke-30.com
#        http://localhost:3000
#   4) "인증 정보" 에서 Client ID 복사 (라벨은 "Client ID" 지만
#      실제 SDK URL 파라미터명은 ncpKeyId — 코드에서 자동 처리)
NEXT_PUBLIC_NCP_MAP_CLIENT_ID=

# (선택) 2D 픽셀/아케이드 스타일 지도 적용:
#   https://www.ncloud.com 로그인 → Maps → Style Editor 접속
#   색·아이콘·픽셀 느낌 지정 후 "발행" → My Style ID 복사
#   아래 env 에 꽂으면 GL 렌더러로 해당 스타일 적용됨.
# NEXT_PUBLIC_NCP_MAP_STYLE_ID=

# ==========================================
# Naver Login
# https://developers.naver.com/apps
# ==========================================
NEXT_PUBLIC_NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=http://localhost:3000/api/auth/callback/naver

# ==========================================
# Google Login
# https://console.cloud.google.com/apis/credentials
# ==========================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# ==========================================
# eBay Browse API (카드 시세)
# https://developer.ebay.com/my/keys
# EBAY_ENV=production 이 기본. sandbox 테스트 시 'sandbox' 로.
# MARKETPLACE_ID: EBAY_US / EBAY_GB / EBAY_DE … (EBAY_KR 없음)
# ==========================================
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_ENV=production

# ==========================================
# Vercel Blob (거래글 사진 첨부)
# Vercel 대시보드 → Storage → Create store → Blob 선택 → 프로젝트 연결 시 자동 주입됨.
# 로컬 개발에서만 필요하면 pull 해서 받아오기:
#   vercel env pull .env.local
# ==========================================
BLOB_READ_WRITE_TOKEN=

# ==========================================
# Ads — Google AdSense
# https://adsense.google.com  → 사이트 등록 후 승인 → 광고 단위 생성
# CLIENT 형식: ca-pub-XXXXXXXXXXXXXXXX
# SLOT 형식  : 10자리 숫자 (광고단위 만들면 발급)
# ==========================================
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT_FEED=

# ==========================================
# Ads — Kakao AdFit
# https://adfit.kakao.com → 매체등록 → 광고단위 생성 (모바일 인피드 320x100 권장)
# 등록한 광고단위 코드(DAN-XXXXXXXX) 그대로 입력
# 예: DAN-iL71cYDIUXbuGNA5
# ==========================================
NEXT_PUBLIC_ADFIT_UNIT_FEED=

# ==========================================
# Google Analytics 4
# https://analytics.google.com → 속성 만들기 → 데이터 스트림 (웹) → 측정 ID
# 형식: G-XXXXXXXXXX
# ==========================================
NEXT_PUBLIC_GA_ID=

# ==========================================
# Search Console / Naver Webmaster 소유권 확인
# 메타태그 인증 방식 사용 시 코드만 입력 (전체 태그 X, content 값만)
# ==========================================
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_NAVER_SITE_VERIFICATION=

# ==========================================
# 정책 페이지 — 운영자 연락처 (privacy/terms 페이지에 노출)
# ==========================================
NEXT_PUBLIC_CONTACT_EMAIL=

# ==========================================
# Optional
# ==========================================
SENTRY_DSN=
RESEND_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=
