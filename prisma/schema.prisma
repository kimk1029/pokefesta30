// Prisma 스키마 — 포케페스타30
// 런타임 URL 은 src/lib/prisma.ts 에서 APP_ENV 에 따라 주입됨.
// CLI(migrate/generate) 는 env("DATABASE_URL") + env("DIRECT_URL") 사용.
//
// Supabase(pgBouncer) 구성:
//   - DATABASE_URL → pooler :6543 + ?pgbouncer=true (런타임 쿼리용)
//   - DIRECT_URL   → 직접 연결 :5432            (prisma migrate 용)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String?
  avatar    String   @default("🐣")
  rating    Int      @default(4)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // profile / inventory (클라이언트 로컬스토리지 대체)
  points           Int       @default(0)
  /// 마지막 출석체크 시각. KST 일자 비교용. null = 아직 출석 한 번도 안 함.
  lastCheckInAt    DateTime?
  /// 연속 출석 일수. 3 의 배수에 도달할 때 보너스 지급.
  streakCount      Int       @default(0)
  avatarId         String    @default("bulbasaur")
  backgroundId     String    @default("default")
  frameId          String    @default("none")
  ownedAvatars     String[]  @default(["bulbasaur", "charmander", "squirtle"])
  ownedBackgrounds String[]  @default(["default"])
  ownedFrames      String[]  @default(["none"])

  trades           Trade[]
  feeds            Feed[]
  feedComments     FeedComment[]
  bookmarks        Bookmark[]
  sentMessages     Message[]      @relation("SentMessages")
  receivedMessages Message[]      @relation("ReceivedMessages")
  oripaTickets     OripaTicket[]
  userCards        UserCard[]
  favoriteCards    FavoriteCard[]
  listingFavorites ListingFavorite[]
  portfolioDailySnapshots PortfolioDailySnapshot[]
  searchLogs       SearchLog[]
  scanLogs         ScanLog[]
  eventPosts       EventPost[]
  eventPostComments EventPostComment[]

  @@map("users")
}

/// 거래 시 만남 장소 (지하철역 등). 페스타 혼잡도 추적은 제거됨.
model Place {
  id        String   @id
  name      String
  emoji     String
  bg        String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trades Trade[]

  @@map("places")
}

model Trade {
  id            Int       @id @default(autoincrement())
  placeId       String
  place         Place     @relation(fields: [placeId], references: [id], onDelete: Cascade)
  type          String // 'buy' | 'sell'
  title         String
  body          String    @default("")
  price         String    @default("제안")
  status        String    @default("open") // 'open' | 'reserved' | 'done' | 'cancelled'
  authorId      String?
  author        User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorEmoji   String    @default("익명")
  authorBgId    String    @default("default")
  authorFrameId String    @default("none")
  kakaoId       String?
  bumpCount     Int       @default(0)
  bumpedAt      DateTime?
  images        Json? // 첨부 사진 URL 배열 (Vercel Blob URL)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  bookmarks Bookmark[]

  @@index([bumpedAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([type])
  @@index([status])
  @@map("trades")
}

/// 커뮤니티 피드 — 자유 게시글. (페스타 혼잡도 제보는 제거됨)
model Feed {
  id            Int      @id @default(autoincrement())
  text          String
  authorId      String?
  author        User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorEmoji   String   @default("🐣")
  authorBgId    String   @default("default")
  authorFrameId String   @default("none")
  /// 첨부 사진 URL 배열 (Vercel Blob URL). 상세 펼침 시에만 노출.
  images        Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bookmarks Bookmark[]
  comments  FeedComment[]

  @@index([createdAt(sort: Desc)])
  @@map("feeds")
}

/// 피드 댓글 — 상세 펼침 시 노출되는 간단 댓글.
model FeedComment {
  id        Int      @id @default(autoincrement())
  feedId    Int
  feed      Feed     @relation(fields: [feedId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  text      String
  createdAt DateTime @default(now())

  @@index([feedId, createdAt])
  @@map("feed_comments")
}

/// 쪽지 (채팅 아닌 비동기 메시지). 웹소켓 없이 폴링 기반.
model Message {
  id         Int       @id @default(autoincrement())
  tradeId    Int?
  senderId   String
  sender     User      @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User      @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  text       String
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([receiverId, readAt])
  @@index([senderId, receiverId, createdAt])
  @@index([tradeId])
  @@map("messages")
}

/// 오리파 티켓 100칸 — 모든 사용자가 공유하는 서버 상태.
/// packId 별로 (index 0..99) 쌍은 유일. 첫 GET 시 없으면 자동 시드.
/// pull 은 updateMany(where drawn:false) 로 원자적 처리 → 경쟁 시 한 명만 성공.
model OripaTicket {
  id            Int       @id @default(autoincrement())
  packId        String
  index         Int
  drawn         Boolean   @default(false)
  grade         String? // 'S' | 'A' | 'B' | 'C'
  prizeName     String?
  prizeEmoji    String?
  prizeImageUrl String?
  drawnById     String?
  drawnBy       User?     @relation(fields: [drawnById], references: [id], onDelete: SetNull)
  drawnByName   String?
  drawnAt       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([packId, index])
  @@index([packId, drawn])
  @@map("oripa_tickets")
}

/// 오리파 팩 정의 — 박스 종류별 가격/상품 풀. 기존 data.ts ORIPA_BOXES 대체.
/// prizes 는 [{grade, name, emoji, weight, bg?}] 배열 JSON.
model OripaPack {
  id           String   @id
  tier         String // 'normal' | 'rare' | 'premium' | 기타 자유
  emoji        String
  name         String
  desc         String
  price        Int // 1회 뽑기당 포인트
  ticketsCount Int      @default(100)
  prizes       Json
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("oripa_packs")
}

/// 오리파 팩 변경 이력 — admin 에서 가격/상품 수정 또는 티켓 초기화 기록.
/// action: 'update' | 'reset_tickets' | 'auto_reset'
/// snapshot: 변경 전/후 핵심 필드 JSON
model OripaPackHistory {
  id        Int      @id @default(autoincrement())
  packId    String
  action    String
  note      String?
  snapshot  Json?
  createdAt DateTime @default(now())

  @@index([packId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("oripa_pack_history")
}

/// 페이지뷰 로그 — path 분석용.
/// (ip, day) 쌍마다 별도 row 로 dedupe 되어 하루 1 IP = 1 방문자 로 집계 (전통적 UV).
/// day 는 서버 UTC 기준 자정 (YYYY-MM-DD 00:00:00). 삽입 시 onConflict 로 중복 무시.
model PageView {
  id        Int      @id @default(autoincrement())
  path      String
  ip        String?
  ua        String?
  userId    String?
  referer   String?
  country   String?
  day       DateTime @db.Date
  createdAt DateTime @default(now())

  @@unique([ip, day])
  @@index([createdAt])
  @@index([path, createdAt])
  @@index([day])
  @@map("page_views")
}

/// 광고 이벤트 로그 — 노출(impression) / 무료충전 시청(reward).
/// AdSense/AdFit 클릭·수익은 광고사 iframe 내부에서 발생해 직접 측정 불가 →
/// 자체로는 노출과 reward 흐름만 기록하고, 클릭/수익은 광고사 콘솔(딥링크) 참조.
/// AdEvent.kind:
///   'impression' — 광고 슬롯 마운트 (network 별)
///   'reward'     — 무료충전소 광고 시청 보상 지급
model AdEvent {
  id        Int      @id @default(autoincrement())
  kind      String // 'impression' | 'reward'
  network   String // 'adsense' | 'adfit' | 'house' | 'offerwall'
  slotId    String // FeedAdRow index 또는 free-charge slot id
  userId    String? // 로그인 사용자만
  reward    Int      @default(0) // reward 시 지급된 포인트
  ip        String?
  ua        String?
  day       DateTime @db.Date // 일별 집계용
  createdAt DateTime @default(now())

  @@index([kind, day])
  @@index([network, day])
  @@index([userId, kind, day])
  @@index([createdAt])
  @@map("ad_events")
}

/// 사용자가 그레이딩/아카이빙한 본인 카드.
/// cardId 는 CARDS_CATALOG 의 id (예: 'magikarp-holo'). 미매칭 카드는 cardId=null + ocrSetCode/ocrCardNumber 로 식별.
/// gradeEstimate / centeringScore 는 모의 그레이딩 결과 스냅샷 (PSA 등급 추정).
model UserCard {
  id             Int      @id @default(autoincrement())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// CARDS_CATALOG id. 매칭 못한 카드는 null.
  cardId         String?
  /// 매칭 실패 시 보조 — OCR 로 추출한 raw 식별자.
  ocrSetCode     String?
  ocrCardNumber  String?
  /// 시세 소스 식별자. 스니덩크 시세 페이지에서 추가한 카드는 여기에 apparelId.
  /// 포트폴리오 합계 계산 시 이 값으로 실시간 시세 조회.
  snkrdunkApparelId Int?
  /// 사용자가 직접 적은 별칭/메모.
  nickname       String?
  memo           String?
  /// 모의 그레이딩 결과 — "PSA 9 (Mint)" 등 라벨 그대로.
  gradeEstimate  String?
  /// 0..100 중심도 점수 (가까운 쪽 비율, 50이면 완벽). worstCloser 그대로 저장.
  centeringScore Float?
  /// 업로드한 카드 사진 URL (Vercel Blob).
  photoUrl       String?
  /// 구매 단가 (정수). 통화는 buyCurrency. 미입력이면 null.
  buyPrice       Int?
  /// 구매가 통화 — 'KRW' | 'JPY'. 기본 KRW.
  buyCurrency    String?  @default("KRW")
  /// 보유 수량. 기본 1.
  qty            Int      @default(1)
  /// 구매 시기 (YYYY-MM 또는 YYYY-MM-DD). 표시용 문자열. 미입력이면 등록일.
  buyDate        String?
  /// 직접뽑기 여부 — true 면 구매가 없이 등록 시점 현재시세를 기준가(buyPrice)로 저장.
  selfPulled     Boolean  @default(false)
  /// 등급(그레이딩) 카드 여부 — true 면 gradeCompany/gradeValue 사용.
  graded         Boolean  @default(false)
  /// 등급사 — 'PSA' | 'BGS' | 'CGC' | 'SGC' 등.
  gradeCompany   String?
  /// 사용자가 입력한 실제 등급 값 — "10", "9.5" 등.
  gradeValue     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, createdAt(sort: Desc)])
  @@index([cardId])
  @@index([snkrdunkApparelId])
  @@map("user_cards")
}

/// 일별 포트폴리오 스냅샷 — 등락율 차트/표시용. KST 일자 키 (YYYY-MM-DD).
/// /api/me/portfolio 호출 시 오늘자 행을 upsert. 어제 행과 비교해 % 계산.
model PortfolioDailySnapshot {
  id          Int      @id @default(autoincrement())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// KST 정각 기준 일자 (예: "2026-05-24"). 같은 일자 내 호출은 upsert 로 갱신만.
  date        String
  /// 스니덩크 최저가 합산 (JPY).
  totalJpy    Int
  pricedCount Int
  totalCount  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date(sort: Desc)])
  @@map("portfolio_daily_snapshots")
}

/// 관심카드 — 사용자가 추적하고 싶은 스니덩크 카드 목록.
/// 포트폴리오 합계에는 포함되지 않고, 단순히 즐겨찾기 용도.
model FavoriteCard {
  id                Int      @id @default(autoincrement())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  snkrdunkApparelId Int
  createdAt         DateTime @default(now())

  @@unique([userId, snkrdunkApparelId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("favorite_cards")
}

/// 외부 매물(네이버 카페 MVC 경매 / 번개장터) 관심목록 — 사용자별.
/// source+externalId 로 식별, 렌더용 메타(제목/이미지/가격/URL)를 함께 캐시해
/// 원본 재조회 없이도 리스트 최상단에 고정 표시.
model ListingFavorite {
  id         Int      @id @default(autoincrement())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 'mvc' | 'bunjang'
  source     String
  /// 카페 articleId 또는 번개 pid (문자열)
  externalId String
  title      String   @default("")
  imageUrl   String?
  /// 호가(원) 또는 번개 가격(원). 모르면 null.
  price      Int?
  url        String   @default("")
  createdAt  DateTime @default(now())

  @@unique([userId, source, externalId])
  @@index([userId, source, createdAt(sort: Desc)])
  @@map("listing_favorites")
}

/// 카드 시세 스냅샷 — eBay Browse API 결과 캐시 + 히스토리 차트용.
/// 10분 이내 스냅샷이면 재사용, 그 이상이면 새로 fetch 후 한 줄 추가.
model CardPriceSnapshot {
  id        Int      @id @default(autoincrement())
  cardId    String
  currency  String   @default("USD")
  low       Float
  avg       Float
  high      Float
  median    Float
  sampleN   Int
  fetchedAt DateTime @default(now())

  @@index([cardId, fetchedAt(sort: Desc)])
  @@map("card_price_snapshots")
}

/// SNKRDUNK 정적 카드 카탈로그 — "하나의 마스터 카드 DB".
/// 시세확인 때 본 카드의 '변하지 않는' 정보(이름/이미지/itemKind/카드번호 등)만 한 행에 누적.
/// 시세는 여기 없고 SnkrdunkPriceSnapshot 에만 — 현재가 = apparelId 별 최신 스냅샷.
/// packCode 는 소속 박스(속성)일 뿐이라 nullable. updatedAt = 마지막 갱신 시각(박스 신선도 판정에 사용).
model SnkrdunkCard {
  /// snkrdunk apparelId (PK).
  apparelId      Int      @id
  name           String   @default("")
  localizedName  String   @default("")
  koName         String   @default("")
  /// 'single' | 'box'
  itemKind       String   @default("single")
  shortName      String   @default("")
  imageUrl       String?
  productNumber  String   @default("")
  /// 박스 출시일 (YYYY-MM-DD).
  releasedAt     String?
  /// 소속 박스 (CARD_PACKS.code). 박스 맥락 없이 본 카드는 null.
  packCode       String?
  /// snkrdunk apparel group id (박스).
  apparelGroupId Int?
  /// 카드 게임 구분: 'pokemon' | 'onepiece' | 'yugioh' | 'other'. '' = 미분류.
  game           String   @default("")
  /// 카드 이름/품번에서 파싱한 세트 코드 (예: "OP02", "SV2A", "QCCP"). 파싱 실패 시 null.
  /// 카드번호와 항상 분리 저장 — 합쳐 쓰지 말 것.
  setCode        String?
  /// 카드 번호 (예: "059", "123/165", "JP049"). 파싱 실패 시 null.
  cardNumber     String?
  /// 레어도 (SAR/SR/UR/CHR 등 — 이름 토큰에서 추출). 없으면 null.
  rarity         String?
  /// 카드를 처음 수집한 시각.
  firstSeenAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([packCode])
  @@map("snkrdunk_cards")
}

/// SNKRDUNK 시세 스냅샷 — 시세 갱신마다 한 줄 누적. 현재가 = apparelId 별 최신 행.
model SnkrdunkPriceSnapshot {
  id           Int      @id @default(autoincrement())
  apparelId    Int
  /// 최저가 (JPY).
  minPrice     Int
  listingCount Int      @default(0)
  /// computeApparelPrices 의 raw 싱글가 (JPY). 0 = 미계산(목록 최저가만 수집한 스냅샷).
  priceSingle  Int      @default(0)
  /// computeApparelPrices 의 PSA10 가 (JPY). 0 = 미계산.
  pricePsa10   Int      @default(0)
  /// sales-chart 일별 시세 시리즈 (number[], 오래된→최신). 컬렉션 스파크라인용.
  trend        Json?
  fetchedAt    DateTime @default(now())

  @@index([apparelId, fetchedAt(sort: Desc)])
  @@map("snkrdunk_price_snapshots")
}

/// 홈 히어로 슬라이더 배너 — 어드민에서 관리.
/// visualType='emoji' 면 visualValue 가 단일 이모지/문자, 'image' 면 정적 경로 또는 URL.
/// onClick: null | 'stamp-rally' | 'oripa' (특수 액션 라우팅)
model HeroBanner {
  id          Int      @id @default(autoincrement())
  /// 정렬 키. 작을수록 먼저 노출.
  sortOrder   Int      @default(0)
  /// 슬라이드 배경 클래스 — 'slide-a' | 'slide-b' | 'slide-c' | 'slide-d'
  slideClass  String   @default("slide-a")
  badge       String
  /// 줄바꿈은 \n 으로 입력
  title       String
  /// 줄바꿈은 \n 으로 입력
  sub         String
  ctaHint     String?
  /// 'emoji' | 'image'
  visualType  String   @default("emoji")
  /// emoji: '💬' 같은 단일 글자, image: '/promo/foo.png'
  visualValue String   @default("✨")
  /// null | 'stamp-rally' | 'oripa' (특수 액션). linkUrl 보다 우선.
  onClick     String?
  /// 클릭 시 이동할 링크. 내부 경로('/cards/...') 또는 외부 URL('https://...').
  /// onClick 특수 액션이 없을 때만 사용. 비우면 비클릭 배너.
  linkUrl     String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active, sortOrder])
  @@map("hero_banners")
}

/// 이벤트 게시판 글 — 어드민 공지 + 회원 작성 글, 웹 /events 에 노출.
/// startsAt/endsAt 은 'YYYY-MM-DD' 문자열. 둘 다 비우면 상시 이벤트.
model EventPost {
  id        Int      @id @default(autoincrement())
  /// 작성자 — null = 어드민 작성 공지.
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  /// 말머리 — '구매' | '시세파악' | '오리파구매'. null = 말머리 없음(공지 등).
  category  String?
  title     String
  /// 본문 — 줄바꿈 \n 그대로 렌더.
  body      String   @default("")
  /// 대표 이미지 URL. 비우면 텍스트 카드.
  imageUrl  String?
  startsAt  String?
  endsAt    String?
  /// 목록 상단 고정.
  pinned    Boolean  @default(false)
  /// false = 비공개(웹 미노출, 어드민에서만 보임).
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  comments  EventPostComment[]

  @@index([published, pinned, createdAt(sort: Desc)])
  @@map("event_posts")
}

/// 이벤트 글 댓글.
model EventPostComment {
  id        Int       @id @default(autoincrement())
  postId    Int
  post      EventPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)
  text      String
  createdAt DateTime  @default(now())

  @@index([postId, createdAt])
  @@map("event_post_comments")
}

model Bookmark {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradeId   Int?
  trade     Trade?   @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  feedId    Int?
  feed      Feed?    @relation(fields: [feedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, tradeId])
  @@unique([userId, feedId])
  @@index([userId])
  @@map("bookmarks")
}

/// 카드 검색 로그 — 사용자가 입력한(한국어) 검색어, 결과 수, 누가(로그인 시), 출처(web/mobile).
model SearchLog {
  id          Int      @id @default(autoincrement())
  query       String
  resultCount Int      @default(0)
  source      String   @default("web")
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([userId])
  @@map("search_logs")
}

/// 사용자 행동 로그 — 회원/비회원 모두의 클릭·페이지이동 등 모든 액션을 한 줄씩 누적(중복제거 없음).
/// PageView(IP·일별 1건 집계)와 달리 세분화된 원시 로그. 어드민 "행동 로그" 화면에서 액션/페이지별 필터.
/// userId 는 PageView 패턴대로 관계 없이 문자열만 — 비회원은 null, 식별은 anonId(클라이언트 생성).
model ActionLog {
  id        Int      @id @default(autoincrement())
  /// 액션 종류: 'pageview' | 'click' | 'tap' 등 (필터 키)
  type      String
  /// 액션이 일어난 페이지 경로 (필터 키)
  path      String   @default("")
  /// 클릭/탭 대상 설명 (예: "a:상세보기", "button:구매"). pageview 면 빈 값.
  target    String   @default("")
  /// 'web' | 'mobile'
  source    String   @default("web")
  /// 로그인 사용자 id. 비회원은 null.
  userId    String?
  /// 비회원 식별용 익명 id (클라이언트 생성, localStorage/AsyncStorage).
  anonId    String?
  ip        String?
  ua        String?
  referer   String?
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([type, createdAt(sort: Desc)])
  @@index([path, createdAt(sort: Desc)])
  @@index([userId])
  @@index([anonId])
  @@map("action_logs")
}

/// 카드 스캔 로그 — 한 번의 카드 스캔(촬영 인식) 요청 1건을 기록.
/// "어떤 엔진으로(engine: vision=OpenAI/paddle=무료 OCR) 어떤 모델·프롬프트로 요청했고
/// (model/prompt/request) 무엇을 인식했으며(extracted) 토큰을 얼마나 썼고(*Tokens)
/// 결과 후보가 몇 건이었는지(candidates)" 를 어드민 "스캔 로그" 화면에서 추적.
/// SearchLog 패턴대로 userId 는 관계로 연결하되 비회원/탈퇴 대비 nullable.
model ScanLog {
  id               Int      @id @default(autoincrement())
  userId           String?
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  /// 'web' | 'app' (모바일)
  source           String   @default("web")
  /// 사용한 OCR 엔진: 'vision'(OpenAI) | 'paddle'(무료) | 'none'(둘 다 실패)
  engine           String   @default("none")
  /// vision 모델명 (예: gpt-4o-mini). paddle/none 이면 null.
  model            String?
  /// 등록 UI 가 보낸 언어 힌트: 'ko' | 'jp' | 'en' | ''
  langHint         String?
  /// 스캔 전체 처리 시간(ms).
  durationMs       Int      @default(0)
  /// 매칭 후보가 1건 이상이면 true.
  success          Boolean  @default(false)
  confidence       Float?
  candidateCount   Int      @default(0)
  imageWidth       Int?
  imageHeight      Int?
  /// OpenAI 토큰 사용량 (vision 경로에서만).
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  /// 요청 상세: 모델 파라미터(detail 레벨·max_tokens·max_dim), useAi, guideRect 등.
  request          Json?
  /// vision 이 사용한 시스템 프롬프트 원문 (요청 방식 감사용).
  prompt           String?
  /// 인식 결과 원본 (name, nameJa, setCode, cardNumber, totalNumber, rarity, language, quad...).
  extracted        Json?
  /// 매칭된 후보 요약 (id, source, name, number, price). 상위 일부만.
  candidates       Json?
  /// snkrdunk 매칭된 apparelId (있으면).
  snkrdunkId       Int?
  /// 실패/예외 메시지 (있으면).
  errorMessage     String?
  createdAt        DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([engine, createdAt(sort: Desc)])
  @@index([success, createdAt(sort: Desc)])
  @@index([userId])
  @@map("scan_logs")
}
