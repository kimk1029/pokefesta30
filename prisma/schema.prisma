// Prisma 스키마 — 포케페스타30
// 런타임 URL 은 src/lib/prisma.ts 에서 APP_ENV 에 따라 주입됨.
// CLI(migrate/generate) 는 env("DATABASE_URL") 사용.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  name        String
  avatar      String   @default("🐣")
  rating      Int      @default(4)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reports   Report[]
  trades    Trade[]
  feeds     Feed[]
  bookmarks Bookmark[]

  @@map("users")
}

model Place {
  id             String    @id
  name           String
  emoji          String
  bg             String
  level          String    @default("empty")
  count          Int       @default(0)
  lastReportAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  reports Report[]
  trades  Trade[]
  feeds   Feed[]

  @@map("places")
}

model Report {
  id          Int      @id @default(autoincrement())
  placeId     String
  place       Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  level       String
  note        String   @default("")
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorEmoji String   @default("익명")
  createdAt   DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([placeId])
  @@map("reports")
}

model Trade {
  id          Int      @id @default(autoincrement())
  placeId     String
  place       Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  type        String   // 'buy' | 'sell'
  title       String
  body        String   @default("")
  price       String   @default("제안")
  status      String   @default("open") // 'open' | 'reserved' | 'done' | 'cancelled'
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorEmoji String   @default("익명")
  kakaoId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookmarks   Bookmark[]

  @@index([createdAt(sort: Desc)])
  @@index([type])
  @@index([status])
  @@map("trades")
}

model Feed {
  id          Int      @id @default(autoincrement())
  placeId     String?
  place       Place?   @relation(fields: [placeId], references: [id], onDelete: SetNull)
  text        String
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorEmoji String   @default("🐣")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookmarks   Bookmark[]

  @@index([createdAt(sort: Desc)])
  @@map("feeds")
}

model Bookmark {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradeId   Int?
  trade     Trade?   @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  feedId    Int?
  feed      Feed?    @relation(fields: [feedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, tradeId])
  @@unique([userId, feedId])
  @@index([userId])
  @@map("bookmarks")
}
