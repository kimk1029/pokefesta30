// Prisma 스키마 — 포케페스타30
// 런타임 URL 은 src/lib/prisma.ts 에서 APP_ENV 에 따라 주입됨.
// CLI(migrate/generate) 는 env("DATABASE_URL") + env("DIRECT_URL") 사용.
//
// Supabase(pgBouncer) 구성:
//   - DATABASE_URL → pooler :6543 + ?pgbouncer=true (런타임 쿼리용)
//   - DIRECT_URL   → 직접 연결 :5432            (prisma migrate 용)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String   @id @default(cuid())
  name        String
  email       String?
  avatar      String   @default("🐣")
  rating      Int      @default(4)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // profile / inventory (클라이언트 로컬스토리지 대체)
  points           Int      @default(0)
  avatarId         String   @default("bulbasaur")
  backgroundId    String   @default("default")
  frameId          String   @default("none")
  ownedAvatars     String[] @default(["bulbasaur","charmander","squirtle"])
  ownedBackgrounds String[] @default(["default"])
  ownedFrames      String[] @default(["none"])

  trades    Trade[]
  feeds     Feed[]
  bookmarks Bookmark[]
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  oripaTickets     OripaTicket[]

  @@map("users")
}

model Place {
  id             String    @id
  name           String
  emoji          String
  bg             String
  level          String    @default("empty")
  count          Int       @default(0)
  lastReportAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  trades Trade[]
  feeds  Feed[]

  @@map("places")
}

model Trade {
  id          Int      @id @default(autoincrement())
  placeId     String
  place       Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  type        String   // 'buy' | 'sell'
  title       String
  body        String   @default("")
  price       String   @default("제안")
  status      String   @default("open") // 'open' | 'reserved' | 'done' | 'cancelled'
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorEmoji      String @default("익명")
  authorBgId       String @default("default")
  authorFrameId    String @default("none")
  kakaoId     String?
  bumpCount   Int      @default(0)
  bumpedAt    DateTime?
  images      Json?    // 첨부 사진 URL 배열 (Vercel Blob URL)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookmarks   Bookmark[]

  @@index([bumpedAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([type])
  @@index([status])
  @@map("trades")
}

/// 통합 피드 — 일반 잡담("general") + 혼잡도 제보("report") 를 한 테이블에서 관리.
/// kind='report' 인 경우 level 필수, 저장 시 places.level/count/lastReportAt 갱신.
model Feed {
  id          Int      @id @default(autoincrement())
  kind        String   @default("general") // 'general' | 'report'
  level       String?                      // kind='report' 일 때만 의미 ('empty'|'normal'|'busy'|'full')
  placeId     String?
  place       Place?   @relation(fields: [placeId], references: [id], onDelete: SetNull)
  text        String
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorEmoji     String  @default("🐣")
  authorBgId      String  @default("default")
  authorFrameId   String  @default("none")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookmarks   Bookmark[]

  @@index([createdAt(sort: Desc)])
  @@index([kind, createdAt(sort: Desc)])
  @@map("feeds")
}

/// 쪽지 (채팅 아닌 비동기 메시지). 웹소켓 없이 폴링 기반.
model Message {
  id         Int      @id @default(autoincrement())
  tradeId    Int?
  senderId   String
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  text       String
  readAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([receiverId, readAt])
  @@index([senderId, receiverId, createdAt])
  @@index([tradeId])
  @@map("messages")
}

/// 오리파 티켓 100칸 — 모든 사용자가 공유하는 서버 상태.
/// packId 별로 (index 0..99) 쌍은 유일. 첫 GET 시 없으면 자동 시드.
/// pull 은 updateMany(where drawn:false) 로 원자적 처리 → 경쟁 시 한 명만 성공.
model OripaTicket {
  id         Int      @id @default(autoincrement())
  packId     String
  index      Int
  drawn      Boolean  @default(false)
  grade      String?  // 'S' | 'A' | 'B' | 'C'
  prizeName  String?
  prizeEmoji String?
  prizeImageUrl String?
  drawnById  String?
  drawnBy    User?    @relation(fields: [drawnById], references: [id], onDelete: SetNull)
  drawnByName String?
  drawnAt    DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([packId, index])
  @@index([packId, drawn])
  @@map("oripa_tickets")
}

/// 오리파 팩 정의 — 박스 종류별 가격/상품 풀. 기존 data.ts ORIPA_BOXES 대체.
/// prizes 는 [{grade, name, emoji, weight, bg?}] 배열 JSON.
model OripaPack {
  id           String   @id
  tier         String   // 'normal' | 'rare' | 'premium' | 기타 자유
  emoji        String
  name         String
  desc         String
  price        Int      // 1회 뽑기당 포인트
  ticketsCount Int      @default(100)
  prizes       Json
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("oripa_packs")
}

/// 오리파 팩 변경 이력 — admin 에서 가격/상품 수정 또는 티켓 초기화 기록.
/// action: 'update' | 'reset_tickets' | 'auto_reset'
/// snapshot: 변경 전/후 핵심 필드 JSON
model OripaPackHistory {
  id        Int      @id @default(autoincrement())
  packId    String
  action    String
  note      String?
  snapshot  Json?
  createdAt DateTime @default(now())

  @@index([packId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("oripa_pack_history")
}

/// 페이지뷰 로그 — path 분석용.
/// (ip, day) 쌍마다 별도 row 로 dedupe 되어 하루 1 IP = 1 방문자 로 집계 (전통적 UV).
/// day 는 서버 UTC 기준 자정 (YYYY-MM-DD 00:00:00). 삽입 시 onConflict 로 중복 무시.
model PageView {
  id        Int      @id @default(autoincrement())
  path      String
  ip        String?
  ua        String?
  userId    String?
  referer   String?
  country   String?
  day       DateTime @db.Date
  createdAt DateTime @default(now())

  @@unique([ip, day])
  @@index([createdAt])
  @@index([path, createdAt])
  @@index([day])
  @@map("page_views")
}

/// 광고 이벤트 로그 — 노출(impression) / 무료충전 시청(reward).
/// AdSense/AdFit 클릭·수익은 광고사 iframe 내부에서 발생해 직접 측정 불가 →
/// 자체로는 노출과 reward 흐름만 기록하고, 클릭/수익은 광고사 콘솔(딥링크) 참조.
/// AdEvent.kind:
///   'impression' — 광고 슬롯 마운트 (network 별)
///   'reward'     — 무료충전소 광고 시청 보상 지급
model AdEvent {
  id        Int      @id @default(autoincrement())
  kind      String   // 'impression' | 'reward'
  network   String   // 'adsense' | 'adfit' | 'house' | 'offerwall'
  slotId    String   // FeedAdRow index 또는 free-charge slot id
  userId    String?  // 로그인 사용자만
  reward    Int      @default(0) // reward 시 지급된 포인트
  ip        String?
  ua        String?
  day       DateTime @db.Date     // 일별 집계용
  createdAt DateTime @default(now())

  @@index([kind, day])
  @@index([network, day])
  @@index([userId, kind, day])
  @@index([createdAt])
  @@map("ad_events")
}

/// 카드 시세 스냅샷 — eBay Browse API 결과 캐시 + 히스토리 차트용.
/// 10분 이내 스냅샷이면 재사용, 그 이상이면 새로 fetch 후 한 줄 추가.
model CardPriceSnapshot {
  id        Int      @id @default(autoincrement())
  cardId    String
  currency  String   @default("USD")
  low       Float
  avg       Float
  high      Float
  median    Float
  sampleN   Int
  fetchedAt DateTime @default(now())

  @@index([cardId, fetchedAt(sort: Desc)])
  @@map("card_price_snapshots")
}

model Bookmark {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradeId   Int?
  trade     Trade?   @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  feedId    Int?
  feed      Feed?    @relation(fields: [feedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, tradeId])
  @@unique([userId, feedId])
  @@index([userId])
  @@map("bookmarks")
}
