// Prisma 스키마 — 포케페스타30
// 런타임 URL 은 src/lib/prisma.ts 에서 APP_ENV 에 따라 주입됨.
// CLI(migrate/generate) 는 env("DATABASE_URL") 사용.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  name        String
  avatar      String   @default("🐣")
  rating      Int      @default(4)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // profile / inventory (클라이언트 로컬스토리지 대체)
  points           Int      @default(1280)
  avatarId         String   @default("bulbasaur")
  backgroundId    String   @default("default")
  frameId          String   @default("none")
  ownedAvatars     String[] @default(["bulbasaur","charmander","squirtle"])
  ownedBackgrounds String[] @default(["default"])
  ownedFrames      String[] @default(["none"])

  trades    Trade[]
  feeds     Feed[]
  bookmarks Bookmark[]
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")

  @@map("users")
}

model Place {
  id             String    @id
  name           String
  emoji          String
  bg             String
  level          String    @default("empty")
  count          Int       @default(0)
  lastReportAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  trades Trade[]
  feeds  Feed[]

  @@map("places")
}

model Trade {
  id          Int      @id @default(autoincrement())
  placeId     String
  place       Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  type        String   // 'buy' | 'sell'
  title       String
  body        String   @default("")
  price       String   @default("제안")
  status      String   @default("open") // 'open' | 'reserved' | 'done' | 'cancelled'
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorEmoji      String @default("익명")
  authorBgId       String @default("default")
  authorFrameId    String @default("none")
  kakaoId     String?
  bumpCount   Int      @default(0)
  bumpedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookmarks   Bookmark[]

  @@index([createdAt(sort: Desc)])
  @@index([type])
  @@index([status])
  @@map("trades")
}

/// 통합 피드 — 일반 잡담("general") + 혼잡도 제보("report") 를 한 테이블에서 관리.
/// kind='report' 인 경우 level 필수, 저장 시 places.level/count/lastReportAt 갱신.
model Feed {
  id          Int      @id @default(autoincrement())
  kind        String   @default("general") // 'general' | 'report'
  level       String?                      // kind='report' 일 때만 의미 ('empty'|'normal'|'busy'|'full')
  placeId     String?
  place       Place?   @relation(fields: [placeId], references: [id], onDelete: SetNull)
  text        String
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorEmoji     String  @default("🐣")
  authorBgId      String  @default("default")
  authorFrameId   String  @default("none")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookmarks   Bookmark[]

  @@index([createdAt(sort: Desc)])
  @@index([kind, createdAt(sort: Desc)])
  @@map("feeds")
}

/// 쪽지 (채팅 아닌 비동기 메시지). 웹소켓 없이 폴링 기반.
model Message {
  id         Int      @id @default(autoincrement())
  tradeId    Int?
  senderId   String
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  text       String
  readAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([receiverId, readAt])
  @@index([senderId, receiverId, createdAt])
  @@index([tradeId])
  @@map("messages")
}

model Bookmark {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradeId   Int?
  trade     Trade?   @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  feedId    Int?
  feed      Feed?    @relation(fields: [feedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, tradeId])
  @@unique([userId, feedId])
  @@index([userId])
  @@map("bookmarks")
}
