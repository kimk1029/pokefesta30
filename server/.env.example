# =============================================================================
#  pokefesta30 Express server -- environment template
#  Copy to `.env` (gitignored) and fill in values for your deployment.
#  Mirrors the variables previously held in the Next.js Vercel project that
#  have been moved to this server during the API migration.
# =============================================================================


# -----------------------------------------------------------------------------
#  Listener
# -----------------------------------------------------------------------------
PORT=3030
NODE_ENV=development


# -----------------------------------------------------------------------------
#  Database (shared Prisma schema at ../prisma/schema.prisma)
#  - DATABASE_URL    : connection used by the server (Supabase pooler in prod).
#  - DIRECT_URL      : direct connection on :5432 -- needed by `prisma migrate`
#                      and the admin deploy workflow. The server itself does
#                      not read DIRECT_URL at runtime.
#  - APP_ENV         : when set to "production" the server falls back to
#                      DATABASE_URL_PRODUCTION (if provided) instead of
#                      DATABASE_URL. Lets a single .env carry both targets.
# -----------------------------------------------------------------------------
DATABASE_URL=
DIRECT_URL=
APP_ENV=
DATABASE_URL_PRODUCTION=


# -----------------------------------------------------------------------------
#  Session / JWT
#  - JWT_SECRET            : openssl rand -hex 64
#  - JWT_EXPIRES_IN        : jose-compatible duration (e.g. "30d", "12h").
#  - SESSION_COOKIE_NAME   : MUST match what the Next.js web reads (default
#                            "pf30_session"). The web's apiServer.ts forwards
#                            this cookie to the server on every request.
#  - COOKIE_DOMAIN         : prod ".example.com" form for cross-subdomain
#                            cookies. Leave blank in dev (localhost does NOT
#                            accept a Domain= attribute).
# -----------------------------------------------------------------------------
JWT_SECRET=
JWT_EXPIRES_IN=30d
SESSION_COOKIE_NAME=pf30_session
COOKIE_DOMAIN=


# -----------------------------------------------------------------------------
#  CORS
#  Comma-separated allow-list. Blank = allow all origins (dev only).
#  Production MUST list exact origins:
#    CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
# -----------------------------------------------------------------------------
CORS_ORIGINS=


# -----------------------------------------------------------------------------
#  Post-login redirects
#  - WEB_BASE_URL              : where the OAuth callback 302s after success.
#                                Set to the production web origin in prod.
#  - MOBILE_DEEP_LINK_SCHEME   : Expo app.json `scheme`. The OAuth callback
#                                redirects to `{scheme}://auth?token=...`
#                                so the mobile app can capture the JWT.
# -----------------------------------------------------------------------------
WEB_BASE_URL=http://localhost:3000
MOBILE_DEEP_LINK_SCHEME=pokefesta30


# -----------------------------------------------------------------------------
#  Admin allow-list
#  Comma-separated emails. Users matching one of these are treated as admin
#  on both the server admin routes and the Next.js admin pages.
# -----------------------------------------------------------------------------
ADMIN_EMAILS=


# -----------------------------------------------------------------------------
#  OAuth -- Kakao
#  REDIRECT_URI must EXACTLY match the value registered in the Kakao Developer
#  console. In production point it at the public server domain:
#    https://api.your-domain.com/auth/callback/kakao
#  In local dev Next rewrites /auth/* to this server, so localhost:3000 works.
# -----------------------------------------------------------------------------
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:3000/auth/callback/kakao


# -----------------------------------------------------------------------------
#  OAuth -- Naver
# -----------------------------------------------------------------------------
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=http://localhost:3000/auth/callback/naver


# -----------------------------------------------------------------------------
#  OAuth -- Google
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback/google


# -----------------------------------------------------------------------------
#  Vision OCR (optional)
#  Opt-in path. Requests with useAi=true call OpenAI GPT-4o-mini for full-card
#  extraction (Korean / Japanese names + bottom-left metadata). If unset, the
#  server falls back to Tesseract.
#  - VISION_MODEL          : OpenAI model id. Default "gpt-4o-mini".
#  - VISION_MAX_DIM        : downscale long-edge before upload (px).
#  - VISION_FULL_DETAIL    : "high" | "low" | "auto" -- image_detail for the
#                            full-card pass.
#  - VISION_ZOOM_DETAIL    : same, for the zoomed bottom-left pass.
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# VISION_MODEL=gpt-4o-mini
# VISION_MAX_DIM=1536
# VISION_FULL_DETAIL=high
# VISION_ZOOM_DETAIL=high


# -----------------------------------------------------------------------------
#  PaddleOCR sidecar (optional)
#  Free Korean-tuned OCR fallback. Server probes /health, falls back to
#  Tesseract when unreachable. Run `python3 server/paddle/ocr.py` on :3002.
# -----------------------------------------------------------------------------
# PADDLE_OCR_URL=http://127.0.0.1:3002


# -----------------------------------------------------------------------------
#  Vercel Blob (image uploads)
#  Used by /api/upload/feed-images and /api/upload/trade-images. Issue token
#  in the Vercel dashboard for the project that owns the blob store.
# -----------------------------------------------------------------------------
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...


# -----------------------------------------------------------------------------
#  eBay finder API (optional)
#  Used by snkrdunk-side price comparisons. Sandbox vs production toggled by
#  EBAY_ENV. Marketplace + scope rarely need changing from the defaults below.
# -----------------------------------------------------------------------------
# EBAY_CLIENT_ID=
# EBAY_CLIENT_SECRET=
# EBAY_ENV=production
# EBAY_MARKETPLACE_ID=EBAY_US
# EBAY_OAUTH_SCOPE=https://api.ebay.com/oauth/api_scope


# -----------------------------------------------------------------------------
#  PSA Public API (optional)
#  Card population report (pop counts per grade) on the price-detail screens.
#  Generate a token at https://www.psacard.com/publicapi (sign in -> Generate
#  Access Token). Free tier = 100 calls/day; the server caches pops for 7 days
#  and stops calling after PSA_DAILY_LIMIT calls (default 80). Unset = the PSA
#  pop section is hidden entirely.
# -----------------------------------------------------------------------------
# PSA_API_TOKEN=
# PSA_DAILY_LIMIT=80
#  PSA's Cloudflare hard-blocks the Korean home IP (NAS line) -> direct calls
#  403. Calls fall back through the Vercel web app's /api/psa-relay (US
#  egress). Default origin below; set empty to disable the fallback.
#  PSA_RELAY_KEY: optional shared secret — set the same value in Vercel env
#  to lock the relay down to this server.
# PSA_RELAY_ORIGIN=https://www.poke-30.com
# PSA_RELAY_KEY=


# -----------------------------------------------------------------------------
#  FX overrides (optional)
#  Hard-coded exchange rates the server falls back to when the live FX feed
#  isn't reachable. Override here if the defaults drift too far.
# -----------------------------------------------------------------------------
# FX_USD_JPY=
# FX_USD_KRW=
# FX_EUR_JPY=
# FX_EUR_KRW=
