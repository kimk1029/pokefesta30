# --- listener ---
PORT=3030
# production 에서는 HTTPS + COOKIE_DOMAIN 설정 필요.
NODE_ENV=development

# --- DB (루트 prisma schema 공유) ---
# 루트 .env / .env.local 과 동일한 값을 쓰거나, server 전용으로 분리해도 됨.
DATABASE_URL=
# 운영 DB 분리: APP_ENV=production 이면 DATABASE_URL_PRODUCTION 사용.
APP_ENV=
DATABASE_URL_PRODUCTION=

# --- 세션 / JWT ---
# 새로 발급: openssl rand -hex 64
JWT_SECRET=
JWT_EXPIRES_IN=30d
SESSION_COOKIE_NAME=pf30_session
# 운영: .example.com 형태. dev 는 비워둘 것 (localhost 는 도메인 지정 X).
COOKIE_DOMAIN=

# --- CORS ---
# 콤마로 구분. 비우면 모든 origin 허용 (dev 전용). 운영에서는 반드시 채울 것.
# 예) CORS_ORIGINS="https://example.com,https://app.example.com"
CORS_ORIGINS=

# --- 로그인 완료 후 리다이렉트 ---
# 웹 (브라우저) 도메인. callback 끝나면 여기로 302.
WEB_BASE_URL=http://localhost:3000
# 모바일 딥링크 스킴 (app.json scheme). 기본값 pokefesta30.
MOBILE_DEEP_LINK_SCHEME=pokefesta30

# --- 어드민 화이트리스트 ---
# 콤마 구분 이메일. 기존 ADMIN_EMAILS 와 동일 의미.
ADMIN_EMAILS=

# --- OAuth: Kakao ---
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
# DEV: Next 가 /auth/* 를 server 로 프록시하므로 redirect 는 localhost:3000 로.
KAKAO_REDIRECT_URI=http://localhost:3000/auth/callback/kakao

# --- OAuth: Naver ---
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=http://localhost:3000/auth/callback/naver

# --- OAuth: Google ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback/google

# --- (기존) Vision OCR 옵션 ---
# Vision (GPT-4o-mini) 은 opt-in: useAi=true + 이 키 둘 다 필요.
# OPENAI_API_KEY=sk-...
# VISION_MODEL=gpt-4o-mini
